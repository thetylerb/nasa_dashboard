# ── NASA API ──────────────────────────────────────────────────────────────────
# Get a free key at https://api.nasa.gov
NASA_API_KEY=your_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Railway: this is injected automatically when you add the PostgreSQL plugin.
# Local dev (after running `docker-compose up`):
DATABASE_URL=postgresql://nasa:nasa_secret@localhost:5432/nasa_pipeline

# ── API service URL ───────────────────────────────────────────────────────────
# Used by the Streamlit frontend to call the FastAPI backend.
# Local dev:
API_BASE_URL=http://localhost:8000
# Railway (set this to the API service's public URL after first deploy):
# API_BASE_URL=https://your-api-service.up.railway.app
